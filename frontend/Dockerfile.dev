# =========================================================================
# DOCKERFILE PARA DESARROLLO (Entorno local con Hot-Reload de Vite)
# =========================================================================
FROM node:22-alpine AS dev
WORKDIR /app

# Instalar pnpm de forma global sincronizada con el entorno general
RUN corepack enable && corepack prepare pnpm@11.3.0 --activate

# Copiar manifiestos de dependencias
COPY package.json pnpm-lock.yaml* ./

# Instalar dependencias en desarrollo de forma completa
RUN pnpm install

# Copiar el código fuente (Útil como base si no se usan volúmenes bind-mount)
COPY . .

# Exponer el puerto por defecto del servidor de desarrollo de Vite
EXPOSE 5173

# Comando para desarrollo forzando la escucha en todas las interfaces de red del contenedor
CMD ["pnpm", "run", "dev", "--", "--host", "0.0.0.0"]